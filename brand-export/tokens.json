{
  "$schema": "https://schemas.shouks.com/design-tokens/v1.json",
  "name": "shouks-brand",
  "version": "1.0.0",
  "updated": "2026-04-20",
  "description": "Canonical design tokens for Shouks. Format: W3C Design Tokens community draft. Values are source of truth; CSS variable names in $extensions.css.variable.",

  "color": {
    "background": {
      "bg":        { "$type": "color", "$value": "#ffffff",              "$extensions": { "css.variable": "--bg" } },
      "bg-soft":   { "$type": "color", "$value": "oklch(0.975 0.003 230)", "$extensions": { "css.variable": "--bg-soft" } },
      "bg-panel":  { "$type": "color", "$value": "oklch(0.96 0.004 230)",  "$extensions": { "css.variable": "--bg-panel" } },
      "surface":   { "$type": "color", "$value": "#ffffff",                "$extensions": { "css.variable": "--surface" } }
    },
    "text": {
      "ink":       { "$type": "color", "$value": "oklch(0.2 0.02 240)",  "$extensions": { "css.variable": "--ink",       "use": "Primary text" } },
      "ink-soft":  { "$type": "color", "$value": "oklch(0.38 0.02 240)", "$extensions": { "css.variable": "--ink-soft",  "use": "Body secondary, paragraph text under headlines" } },
      "muted":     { "$type": "color", "$value": "oklch(0.55 0.015 240)","$extensions": { "css.variable": "--muted",     "use": "Captions, meta, placeholder, eyebrows" } }
    },
    "line": {
      "line":      { "$type": "color", "$value": "oklch(0.9 0.005 230)",  "$extensions": { "css.variable": "--line",      "use": "Default border, card outlines" } },
      "line-soft": { "$type": "color", "$value": "oklch(0.93 0.004 230)", "$extensions": { "css.variable": "--line-soft", "use": "Subtle dividers inside cards" } },
      "hover":     { "$type": "color", "$value": "oklch(0.95 0.005 230)", "$extensions": { "css.variable": "--hover",     "use": "Hover background on list rows, nav" } }
    },
    "brand": {
      "blue":        { "$type": "color", "$value": "oklch(0.66 0.16 230)", "$extensions": { "css.variable": "--blue",        "use": "Brand primary; logo core, accent fills" } },
      "blue-ink":    { "$type": "color", "$value": "oklch(0.5 0.15 232)",  "$extensions": { "css.variable": "--blue-ink",    "use": "Links, emphasized serif italics, inline brand text" } },
      "blue-soft":   { "$type": "color", "$value": "oklch(0.96 0.03 230)", "$extensions": { "css.variable": "--blue-soft",   "use": "Tinted badge/chip background" } },
      "blue-softer": { "$type": "color", "$value": "oklch(0.98 0.015 230)","$extensions": { "css.variable": "--blue-softer", "use": "Very subtle brand wash on large surfaces" } }
    },
    "semantic": {
      "success":      { "$type": "color", "$value": "oklch(0.58 0.12 155)", "$extensions": { "css.variable": "--success" } },
      "success-soft": { "$type": "color", "$value": "oklch(0.95 0.04 155)", "$extensions": { "css.variable": "--success-soft" } },
      "warn":         { "$type": "color", "$value": "oklch(0.72 0.13 75)",  "$extensions": { "css.variable": "--warn" } },
      "warn-soft":    { "$type": "color", "$value": "oklch(0.97 0.04 75)",  "$extensions": { "css.variable": "--warn-soft" } },
      "danger":       { "$type": "color", "$value": "oklch(0.55 0.18 25)",  "$extensions": { "css.variable": "--danger" } },
      "danger-soft":  { "$type": "color", "$value": "oklch(0.96 0.035 25)", "$extensions": { "css.variable": "--danger-soft" } },
      "amber":        { "$type": "color", "$value": "oklch(0.72 0.14 65)",  "$extensions": { "css.variable": "--amber" } },
      "amber-soft":   { "$type": "color", "$value": "oklch(0.97 0.04 65)",  "$extensions": { "css.variable": "--amber-soft" } }
    }
  },

  "typography": {
    "family": {
      "sans":  { "$type": "fontFamily", "$value": ["IBM Plex Sans", "system-ui", "sans-serif"], "$extensions": { "google.font": "IBM+Plex+Sans:wght@400;500;600;700", "use": "UI, body, numerals, nav — 95% of text" } },
      "serif": { "$type": "fontFamily", "$value": ["Source Serif 4", "serif"],                   "$extensions": { "google.font": "Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,500;0,8..60,600;1,8..60,400;1,8..60,500", "use": "Display, H1–H2, italic emphasis, pull-quotes", "optical-sizing": "auto" } },
      "mono":  { "$type": "fontFamily", "$value": ["ui-monospace", "SF Mono", "Menlo", "monospace"],                "$extensions": { "use": "Eyebrow labels, IDs, codes, URLs" } }
    },
    "weight": {
      "regular":  { "$type": "fontWeight", "$value": 400 },
      "medium":   { "$type": "fontWeight", "$value": 500 },
      "semibold": { "$type": "fontWeight", "$value": 600 },
      "bold":     { "$type": "fontWeight", "$value": 700 }
    },
    "scale": {
      "display": { "$type": "typography", "$value": { "fontFamily": "{typography.family.serif}", "fontSize": "clamp(48px, 6vw, 72px)", "fontWeight": 500, "letterSpacing": "-0.015em", "lineHeight": 1.02, "fontStyle": "normal" }, "$extensions": { "use": "Hero moments, full-screen states. Italic for emphasized phrase." } },
      "h1":      { "$type": "typography", "$value": { "fontFamily": "{typography.family.serif}", "fontSize": "32px",               "fontWeight": 500, "letterSpacing": "-0.01em",  "lineHeight": 1.1 },  "$extensions": { "use": "Page / wizard titles" } },
      "h2":      { "$type": "typography", "$value": { "fontFamily": "{typography.family.serif}", "fontSize": "22px",               "fontWeight": 500, "letterSpacing": "-0.005em", "lineHeight": 1.2 },  "$extensions": { "use": "Section / screen captions" } },
      "amount":  { "$type": "typography", "$value": { "fontFamily": "{typography.family.sans}",  "fontSize": "18px",               "fontWeight": 500, "letterSpacing": "-0.01em",  "fontVariantNumeric": "tabular-nums" }, "$extensions": { "use": "Bids, prices, totals \u2014 any time money is the subject" } },
      "h3":      { "$type": "typography", "$value": { "fontFamily": "{typography.family.sans}",  "fontSize": "15px",               "fontWeight": 600, "letterSpacing": "-0.01em",  "lineHeight": 1.3 },  "$extensions": { "use": "Card titles, key groupings" } },
      "h4":      { "$type": "typography", "$value": { "fontFamily": "{typography.family.sans}",  "fontSize": "14px",               "fontWeight": 600, "letterSpacing": "-0.005em", "lineHeight": 1.4 },  "$extensions": { "use": "Subsection headings" } },
      "body":    { "$type": "typography", "$value": { "fontFamily": "{typography.family.sans}",  "fontSize": "13.5px",             "fontWeight": 400, "letterSpacing": "-0.005em", "lineHeight": 1.5 },  "$extensions": { "use": "Default text" } },
      "small":   { "$type": "typography", "$value": { "fontFamily": "{typography.family.sans}",  "fontSize": "12.5px",             "fontWeight": 400, "lineHeight": 1.5 },                             "$extensions": { "use": "Secondary UI, form help", "color": "{color.text.ink-soft}" } },
      "caption": { "$type": "typography", "$value": { "fontFamily": "{typography.family.sans}",  "fontSize": "11.5px",             "fontWeight": 500, "lineHeight": 1.45 },                            "$extensions": { "use": "Meta, timestamps, helper", "color": "{color.text.muted}" } },
      "eyebrow": { "$type": "typography", "$value": { "fontFamily": "{typography.family.mono}",  "fontSize": "11px",               "fontWeight": 600, "letterSpacing": "0.14em",   "textTransform": "uppercase" }, "$extensions": { "use": "All-caps labels, section tags", "color": "{color.text.muted}" } },
      "mono":    { "$type": "typography", "$value": { "fontFamily": "{typography.family.mono}",  "fontSize": "12.5px" },                                                                              "$extensions": { "use": "URLs, IDs, codes", "color": "{color.text.ink-soft}" } }
    }
  },

  "space": {
    "1":  { "$type": "dimension", "$value": "4px",  "$extensions": { "css.variable": "--space-1",  "use": "Inline gaps, icon padding" } },
    "2":  { "$type": "dimension", "$value": "8px",  "$extensions": { "css.variable": "--space-2",  "use": "Tight grouping" } },
    "3":  { "$type": "dimension", "$value": "12px", "$extensions": { "css.variable": "--space-3",  "use": "Default gap" } },
    "4":  { "$type": "dimension", "$value": "16px", "$extensions": { "css.variable": "--space-4",  "use": "Card internal padding" } },
    "6":  { "$type": "dimension", "$value": "24px", "$extensions": { "css.variable": "--space-6",  "use": "Section gap, page margin" } },
    "8":  { "$type": "dimension", "$value": "32px", "$extensions": { "css.variable": "--space-8",  "use": "Large groupings" } },
    "11": { "$type": "dimension", "$value": "44px", "$extensions": { "css.variable": "--space-11", "use": "Wizard padding" } },
    "15": { "$type": "dimension", "$value": "60px", "$extensions": { "css.variable": "--space-15", "use": "Hero, stage top" } }
  },

  "radius": {
    "xs":   { "$type": "dimension", "$value": "4px",   "$extensions": { "css.variable": "--r-xs",   "use": "Micro chips, tag labels" } },
    "sm":   { "$type": "dimension", "$value": "7px",   "$extensions": { "css.variable": "--r-sm",   "use": "Small buttons, nav chips" } },
    "md":   { "$type": "dimension", "$value": "8px",   "$extensions": { "css.variable": "--r-md",   "use": "Default button, input" } },
    "lg":   { "$type": "dimension", "$value": "10px",  "$extensions": { "css.variable": "--r-lg",   "use": "Menu items, alerts" } },
    "xl":   { "$type": "dimension", "$value": "12px",  "$extensions": { "css.variable": "--r-xl",   "use": "Cards, modals" } },
    "2xl":  { "$type": "dimension", "$value": "14px",  "$extensions": { "css.variable": "--r-2xl",  "use": "Hero cards, feature tiles" } },
    "full": { "$type": "dimension", "$value": "999px", "$extensions": { "css.variable": "--r-full", "use": "Pills, chips, avatars" } }
  },

  "shadow": {
    "sm": { "$type": "shadow", "$value": "0 1px 2px oklch(0 0 0 / 0.06)",                "$extensions": { "css.variable": "--shadow-sm", "use": "Subtle elevation on hover" } },
    "md": { "$type": "shadow", "$value": "0 1px 3px oklch(0.1 0.02 240 / 0.18)",         "$extensions": { "css.variable": "--shadow",    "use": "Card default elevation" } },
    "lg": { "$type": "shadow", "$value": "0 24px 64px -32px oklch(0.1 0.03 240 / 0.25)", "$extensions": { "css.variable": "--shadow-lg", "use": "Modal, popover, floating sheet" } }
  },

  "brand": {
    "name":     { "$type": "string", "$value": "Shouks" },
    "wordmark": { "$type": "string", "$value": "Shouks",  "$extensions": { "font": "IBM Plex Sans 700", "letter-spacing": "-0.04em", "use": "Always rendered from the provided SVG — never set in live text" } },
    "logo":     {
      "icon":             { "$type": "asset", "$value": "dist/svg/icon/shouks-icon-color.svg" },
      "icon-monochrome":  { "$type": "asset", "$value": "dist/svg/icon/shouks-icon-mono.svg" },
      "icon-reversed":    { "$type": "asset", "$value": "dist/svg/icon/shouks-icon-white.svg" },
      "horizontal":       { "$type": "asset", "$value": "dist/svg/lockup/shouks-horizontal.svg" },
      "stacked":          { "$type": "asset", "$value": "dist/svg/lockup/shouks-stacked.svg" }
    },
    "clear-space":   { "$type": "string", "$value": "Minimum clear space = height of the icon's inner dot on all sides." },
    "minimum-size":  { "$type": "dimension", "$value": "16px", "$extensions": { "use": "Smallest permitted icon width, digital" } }
  }
}

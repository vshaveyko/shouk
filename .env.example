NODE_ENV=development
PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
DATABASE_URL=postgresql://user:password@host:5432/shouks
AUTH_SECRET=generate-a-long-random-string
NEXTAUTH_SECRET=generate-a-long-random-string
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Transactional email — Resend (https://resend.com). Without a key the
# sendEmail helper becomes a dev-mode console.log so local work keeps
# running; production should always have this set.
RESEND_API_KEY=
EMAIL_FROM=Shouks <noreply@example.com>

# Object storage — Railway S3 bucket (https://railway.app/docs/storage)
# Files are served via /api/images/[...key] proxy route, no public bucket needed.
S3_ENDPOINT=https://t3.storageapi.dev
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# WhatsApp group linking — uses whatsapp-web.js + Puppeteer. Off by default
# because it's a heavy dependency (Chromium runtime). When true, the server
# spins up in-memory per-user QR-scan sessions for owners to link groups and
# members to auto-join matching marketplaces. On VPS/Railway set
# WHATSAPP_CHROME_PATH to the installed Chromium binary.
WHATSAPP_ENABLED=false
WHATSAPP_CHROME_PATH=

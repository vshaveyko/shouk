NODE_ENV=development
PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
DATABASE_URL=postgresql://user:password@host:5432/shouks
AUTH_SECRET=generate-a-long-random-string
NEXTAUTH_SECRET=generate-a-long-random-string
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Transactional email — Resend (https://resend.com). Without a key the
# sendEmail helper becomes a dev-mode console.log so local work keeps
# running; production should always have this set.
RESEND_API_KEY=
EMAIL_FROM=Shouks <noreply@example.com>
